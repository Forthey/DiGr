@startuml
autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Парсинг DSL запроса

participant ActorDslEngine as Engine
participant ActorDslParser as ParserApi
participant DslParserRuntimeFactory as ParserFactory
participant ManualActorDriver as ParserDriver
participant DslParserCoordinatorActor as ParserCoordinator
participant DslLexerActor as LexerActor
participant DslQueryParserActor as QueryParserActor
participant DslParseResultCollectorActor as ParseCollector

Engine -> ParserApi: parse(query_source)
activate Engine
activate ParserApi

ParserApi -> ParserFactory: create()
activate ParserFactory
ParserFactory -> ParserDriver: create step_limit=1
ParserFactory -> LexerActor: bind(driver)
ParserFactory -> QueryParserActor: bind(driver)
ParserFactory -> ParseCollector: bind(driver)
ParserFactory -> ParserCoordinator: bind(driver)
ParserFactory --> ParserApi: DslParserRuntime
deactivate ParserFactory

ParserApi -> ParserCoordinator: put(ParseDslRequest)
ParserApi -> ParserDriver: drain()
activate ParserDriver

loop while parser actors are runnable
  ParserDriver -> ParserCoordinator: step(1)
  activate ParserCoordinator
  ParserCoordinator -> LexerActor: put(TokenizeDslRequest)
  deactivate ParserCoordinator

  ParserDriver -> LexerActor: step(1)
  activate LexerActor
  LexerActor -> ParserCoordinator: put(DslTokenized)
  deactivate LexerActor

  ParserDriver -> ParserCoordinator: step(1)
  activate ParserCoordinator
  ParserCoordinator -> QueryParserActor: put(ParseTokenStreamRequest)
  deactivate ParserCoordinator

  ParserDriver -> QueryParserActor: step(1)
  activate QueryParserActor
  QueryParserActor -> ParseCollector: put(DslQueryParsed)
  deactivate QueryParserActor

  ParserDriver -> ParseCollector: step(1)
  activate ParseCollector
  ParseCollector --> ParseCollector: result = query_ast
  deactivate ParseCollector
end

deactivate ParserDriver
ParserApi --> Engine: DslQuery
deactivate ParserApi
deactivate Engine

@enduml
