@startuml
left to right direction
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle

title DiGr - Компонентная диаграмма

package "Actor Runtime" as actor {
  component "Actor Runtime\n(Actor, ActorHandle, Drivers)" as actor_runtime
}

package "Document AST" as ast {
  component "Parser API\n(ActorAstParser)" as ast_api
  component "Format Configuration\n(ConfigLoader, ParserConfig)" as ast_config
  component "Parsing Runtime\n(ParserRuntimeFactory + actors)" as ast_runtime
  component "Source Reading\n(SourceReaderRegistry + readers)" as ast_source
  component "Segmentation\n(TextSegmenter)" as ast_seg
  component "AST Model\n(SourceDocument, AstNode, AstDocument)" as ast_model
}

package "DSL" as dsl {
  component "DSL Parser API\n(ActorDslParser)" as dsl_parser_api
  component "DSL Parser Runtime\n(DslParserRuntimeFactory + actors)" as dsl_parser_runtime
  component "DSL Executor API\n(ActorDslExecutor)" as dsl_executor_api
  component "DSL Execution Runtime\n(DslExecutionRuntimeFactory + actors)" as dsl_execution_runtime
  component "DSL Engine API\n(ActorDslEngine)" as dsl_engine_api
  component "DSL Query Model\n(query_ast)" as dsl_query_model
  component "Execution Semantics\n(DocumentIndex, PredicateEvaluator,\nQueryValidator, QueryResults)" as dsl_execution_semantics
}

database "config/formats/*.yaml" as format_configs

ast_api ..> ast_config : uses
ast_api ..> ast_runtime : uses
ast_api ..> ast_model : exposes

ast_config ..> format_configs : loads

ast_runtime ..> actor_runtime : uses
ast_runtime ..> ast_source : uses
ast_runtime ..> ast_seg : uses
ast_runtime ..> ast_model : builds

ast_source ..> ast_model : creates

dsl_parser_api ..> dsl_parser_runtime : uses
dsl_parser_api ..> dsl_query_model : exposes

dsl_parser_runtime ..> actor_runtime : uses
dsl_parser_runtime ..> dsl_query_model : builds

dsl_executor_api ..> dsl_execution_runtime : uses
dsl_executor_api ..> ast_model : consumes
dsl_executor_api ..> dsl_query_model : consumes

dsl_execution_runtime ..> actor_runtime : uses
dsl_execution_runtime ..> ast_model : traverses
dsl_execution_runtime ..> dsl_query_model : evaluates
dsl_execution_runtime ..> dsl_execution_semantics : uses

dsl_engine_api ..> dsl_parser_api : uses
dsl_engine_api ..> dsl_executor_api : uses
dsl_engine_api ..> ast_model : consumes

note bottom
  Диаграмма показывает только устойчивые зависимости между компонентами.
  Динамический обмен сообщениями между акторами вынесен в sequence diagrams.
end note

@enduml
