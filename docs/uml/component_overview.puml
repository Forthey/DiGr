@startuml
skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle

title DiGr - Компонентная диаграмма (текущее состояние)

package "Document AST" as ast {
  [ActorAstParser\n(публичный API)] as api
  [ConfigLoader] as cl
  [Actor Pipeline\n(Coordinator + Workers)] as pipeline
  [AstBuilder] as builder
  [TextSegmenter\n(Strategy Registry)] as seg
  [SourceReaderRegistry] as srr
}

package "Actor Runtime" as actor {
  [Actor / FSM] as core
  [Drivers\n(Manual, Threaded, Asyncio)] as drivers
  [Mailbox / ActorHandle] as mh
}

package "DSL" as dsl {
  [ActorDslParser] as dsl_parser
  [ActorDslExecutor] as dsl_executor
  [ActorDslEngine] as dsl_engine
  [Execution Runtime\n(Coordinator + Workers)] as dsl_runtime
  [DocumentIndex + PredicateEvaluator] as dsl_eval
}

database "config/formats/*.yaml" as config

api --> cl : загружает конфигурацию
api --> pipeline : создаёт runtime
cl --> config : читает YAML

pipeline --> core : использует акторный рантайм
pipeline --> builder : worker'ы строят поддеревья
pipeline --> srr : reader читает файл
builder --> seg : сегментирует текст

core --> mh : сообщения через mailbox
core --> drivers : scheduling

dsl_parser --> core : использует actor runtime
dsl_parser --> dsl_runtime : parsing pipeline

dsl_executor --> api : использует AstDocument
dsl_executor --> core : использует actor runtime
dsl_executor --> dsl_runtime : execution pipeline
dsl_executor --> dsl_eval : семантика DSL

dsl_engine --> dsl_parser : parse(query)
dsl_engine --> dsl_executor : execute(query_ast)

@enduml
