@startuml
autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

title Sequence: Полный цикл парсинга документа (Fan-out / Fan-in)

actor Client
participant ActorAstParser
participant ConfigLoader
participant ParserRuntimeFactory
participant ManualActorDriver as Driver
participant ParseCoordinatorActor as Coordinator
participant SourceReaderActor as Reader
participant SourceReaderRegistry
participant "SubtreeBuilderWorkerActor[i]" as Worker
participant AstBuilder
participant ParseResultCollectorActor as Collector

Client -> ActorAstParser: parse(path, format_name?)
activate ActorAstParser

opt format_name is None
  ActorAstParser -> ActorAstParser: _detect_format(path)
end

ActorAstParser -> ConfigLoader: load(config/formats/<format>.yaml,\nexpected_format_name)
activate ConfigLoader
ConfigLoader --> ActorAstParser: ParserConfig
deactivate ConfigLoader

ActorAstParser -> ParserRuntimeFactory: create(config)
activate ParserRuntimeFactory
ParserRuntimeFactory -> Driver: create step_limit=1
ParserRuntimeFactory -> Collector: bind(driver)
ParserRuntimeFactory -> Reader: bind(driver)
ParserRuntimeFactory -> Worker: bind(driver) × worker_count
ParserRuntimeFactory -> Coordinator: bind(driver)
ParserRuntimeFactory -> Reader: set_reply_to(coordinator.handle)
ParserRuntimeFactory -> Worker: set_reply_to(coordinator.handle) × N
ParserRuntimeFactory --> ActorAstParser: ParserRuntime
deactivate ParserRuntimeFactory

  ActorAstParser -> Coordinator: put(ParseDocumentRequest)
  note right
    put() кладёт сообщение в mailbox
    и планирует актор в driver.
  end note

ActorAstParser -> Driver: drain()
activate Driver

loop while runnable actors exist

  Driver -> Coordinator: step(1)
  activate Coordinator
  Coordinator -> Reader: tell(ReadDocumentRequest)
  deactivate Coordinator

  Driver -> Reader: step(1)
  activate Reader
  Reader -> SourceReaderRegistry: read(path, format_name, reader_config)
  activate SourceReaderRegistry
  SourceReaderRegistry --> Reader: SourceDocument
  deactivate SourceReaderRegistry
  Reader -> Coordinator: tell(DocumentLoaded)
  deactivate Reader

  Driver -> Coordinator: step(1)
  activate Coordinator
  note right of Coordinator
    Сегментация верхнего уровня.
    Fan-out: N сегментов → N worker'ам.
  end note
  Coordinator -> Worker: tell(BuildSubtreeRequest) × N
  deactivate Coordinator

  Driver -> Worker: step(1)
  activate Worker
  Worker -> AstBuilder: build_entity_node(entity, segment)
  activate AstBuilder
  AstBuilder --> Worker: AstNode
  deactivate AstBuilder
  Worker -> Coordinator: tell(SubtreeCompleted)
  deactivate Worker

  Driver -> Coordinator: step(1)
  activate Coordinator
  note right of Coordinator
    Fan-in: все поддеревья получены.
    Собирает AstDocument.
  end note
  Coordinator -> Collector: tell(ParseCompleted)
  deactivate Coordinator

  Driver -> Collector: step(1)
  activate Collector
  Collector --> Collector: result = document
  deactivate Collector
end

deactivate Driver

ActorAstParser --> Client: AstDocument
deactivate ActorAstParser

@enduml
