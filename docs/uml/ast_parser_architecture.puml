@startuml
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam shadowing false
hide empty members

package "document_ast.config" {
  class ConfigLoader {
    +load(path, expected_format_name)
  }

  class ParserConfig {
    +format_config: FormatConfig
    +entities: dict
    +format_name
    +get_entity(entity_name)
  }

  class FormatConfig {
    +name: str
    +reader: dict
    +root_entity: str
  }

  class EntityConfig {
    +name: str
    +contains: str
    +segmenter: dict
  }

  ParserConfig *-- "1" FormatConfig
  ParserConfig *-- "1..*" EntityConfig
  ConfigLoader --> ParserConfig : создаёт
}

package "document_ast.source" {
  abstract class SourceReader {
    +read(path, format_name, reader_config)
  }

  class PlainTextReader {
    +read(path, format_name, reader_config)
  }

  class SourceReaderRegistry {
    -_readers: dict
    +read(path, format_name, reader_config)
  }

  class SourceDocument {
    +path: str
    +format_name: str
    +text: str
  }

  SourceReader <|-- PlainTextReader
  SourceReaderRegistry o-- "1..*" SourceReader
  SourceReader --> SourceDocument : создаёт
}

package "document_ast.segmentation" {
  abstract class SegmentStrategy {
    +segment(text, base_start, config)
  }

  class PassthroughStrategy
  class SplitStrategy
  class MatchStrategy

  class TextSegmenter {
    -_strategies: dict
    +register(kind, strategy)
    +segment(text, base_start, config)
  }

  class TextSegment {
    +text: str
    +start: int
    +end: int
  }

  SegmentStrategy <|-- PassthroughStrategy
  SegmentStrategy <|-- SplitStrategy
  SegmentStrategy <|-- MatchStrategy
  TextSegmenter o-- "1..*" SegmentStrategy
  TextSegmenter --> "0..*" TextSegment : создаёт
}

package "document_ast.model" {
  class AstBuilder {
    -_config: ParserConfig
    -_segmenter: TextSegmenter
    +build(document)
    +build_entity_node(entity_name, segment)
  }

  class AstDocument {
    +source_path: str
    +format_name: str
    +root_entity: str
    +root: AstNode
    +to_dict()
  }

  class AstNode {
    +entity: str
    +text: str
    +start: int
    +end: int
    +children: list
    +metadata: dict
    +to_dict()
  }

  AstBuilder --> ParserConfig
  AstBuilder --> TextSegmenter
  AstBuilder --> SourceDocument
  AstBuilder --> AstDocument : создаёт
  AstDocument *-- "1" AstNode : root
  AstNode *-- "0..*" AstNode : children
}

package "document_ast.runtime" {
  enum CoordinatorState {
    IDLE
    WAITING_FOR_DOCUMENT
    BUILDING_SUBTREES
    COMPLETED
  }

  enum WorkerState {
    IDLE
  }

  class ParserRuntime {
    +driver
    +coordinator: ParserCoordinatorActor
    +collector: ResultCollectorActor
  }

  class ParserRuntimeFactory {
    -_worker_count: int
    -_driver_factory
    +create(config)
  }

  class ParserCoordinatorActor {
    -_config: ParserConfig
    -_reader
    -_workers: list
    -_collector
    -_pending_count: int
    -_subtree_results: dict
    -_document: SourceDocument
    -_segmenter: TextSegmenter
  }

  class DocumentReaderActor {
    -_config: ParserConfig
    -_reply_to
    -_registry: SourceReaderRegistry
    +set_reply_to(handle)
  }

  class SubtreeWorkerActor {
    -_builder: AstBuilder
    -_reply_to
    +set_reply_to(handle)
  }

  class ResultCollectorActor {
    +result: AstDocument
  }

  ParserRuntimeFactory --> ParserRuntime : создаёт
  ParserRuntimeFactory --> ParserConfig
  ParserRuntimeFactory --> ParserCoordinatorActor : создаёт
  ParserRuntimeFactory --> DocumentReaderActor : создаёт
  ParserRuntimeFactory --> SubtreeWorkerActor : создаёт ×N
  ParserRuntimeFactory --> ResultCollectorActor : создаёт

  ParserRuntime *-- "1" ParserCoordinatorActor
  ParserRuntime *-- "1" ResultCollectorActor

  ParserCoordinatorActor --> ParserConfig
  ParserCoordinatorActor --> TextSegmenter
  ParserCoordinatorActor --> SourceDocument
  ParserCoordinatorActor --> AstDocument
  DocumentReaderActor --> ParserConfig
  DocumentReaderActor --> SourceReaderRegistry
  DocumentReaderActor --> SourceDocument
  SubtreeWorkerActor --> AstBuilder
  SubtreeWorkerActor --> AstNode
  ResultCollectorActor --> AstDocument
}
@enduml
