@startuml
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam shadowing false
hide empty members

package "actor.api" {
  abstract class Actor
  class ActorHandle
  class ManualActorDriver
}

package "document_ast.api" {
  class ActorAstParser {
    -_config_dir: Path
    -_loader: ConfigLoader
    +from_config_dir(path)
    +parse(path, format_name)
  }
}

package "document_ast.config" {
  class ConfigLoader {
    +load(path, expected_format_name)
  }

  class ParserConfig {
    +format_config: FormatConfig
    +entities: dict
    +format_name
    +get_entity(entity_name)
  }

  class FormatConfig {
    +name: str
    +reader: dict
    +root_entity: str
  }

  class EntityConfig {
    +name: str
    +contains: str
    +segmenter: dict
  }

  ParserConfig *-- "1" FormatConfig
  ParserConfig *-- "1..*" EntityConfig
  ConfigLoader --> ParserConfig : создаёт
}

package "document_ast.source" {
  abstract class SourceReader {
    +read(path, format_name, reader_config)
  }

  class PlainTextReader {
    +read(path, format_name, reader_config)
  }

  class SourceReaderRegistry {
    -_readers: dict
    +read(path, format_name, reader_config)
  }

  class SourceDocument {
    +path: str
    +format_name: str
    +text: str
  }

  SourceReader <|-- PlainTextReader
  SourceReaderRegistry o-- "1..*" SourceReader
  SourceReader --> SourceDocument : создаёт
}

package "document_ast.segmentation" {
  abstract class SegmentStrategy {
    +segment(text, base_start, config)
  }

  class PassthroughStrategy
  class SplitStrategy
  class MatchStrategy

  class TextSegmenter {
    -_strategies: dict
    +register(kind, strategy)
    +segment(text, base_start, config)
  }

  class TextSegment {
    +text: str
    +start: int
    +end: int
  }

  SegmentStrategy <|-- PassthroughStrategy
  SegmentStrategy <|-- SplitStrategy
  SegmentStrategy <|-- MatchStrategy
  TextSegmenter o-- "1..*" SegmentStrategy
  TextSegmenter --> "0..*" TextSegment : создаёт
}

package "document_ast.model" {
  class AstBuilder {
    -_config: ParserConfig
    -_segmenter: TextSegmenter
    +build(document)
    +build_entity_node(entity_name, segment)
  }

  class AstDocument {
    +source_path: str
    +format_name: str
    +root_entity: str
    +root: AstNode
    +to_dict()
  }

  class AstNode {
    +entity: str
    +text: str
    +start: int
    +end: int
    +children: list
    +metadata: dict
    +to_dict()
  }

  AstBuilder --> ParserConfig
  AstBuilder --> TextSegmenter
  AstBuilder --> SourceDocument
  AstBuilder --> AstDocument : создаёт
  AstDocument *-- "1" AstNode : root
  AstNode *-- "0..*" AstNode : children
}

package "document_ast.runtime" {
  enum CoordinatorState {
    IDLE
    WAITING_FOR_DOCUMENT
    BUILDING_SUBTREES
    COMPLETED
  }

  enum WorkerState {
    IDLE
  }

  class ParseDocumentRequest {
    +path: str
    +format_name: str
  }

  class ReadDocumentRequest {
    +path: str
    +format_name: str
  }

  class DocumentLoaded {
    +document: SourceDocument
  }

  class BuildSubtreeRequest {
    +segment_index: int
    +entity_name: str
    +segment: TextSegment
  }

  class SubtreeCompleted {
    +segment_index: int
    +node: AstNode
  }

  class ParseCompleted {
    +document: AstDocument
  }

  class ParserRuntime {
    +driver: ProceedableActorDriver
    +coordinator: ParserCoordinatorActor
    +collector: ResultCollectorActor
  }

  class ParserRuntimeFactory {
    -_worker_count: int
    -_driver_factory
    +create(config)
  }

  class ParserCoordinatorActor {
    -_config: ParserConfig
    -_reader: ActorHandle
    -_workers: list[ActorHandle]
    -_collector: ActorHandle
    -_segmenter: TextSegmenter
  }

  class DocumentReaderActor {
    -_config: ParserConfig
    -_reply_to: ActorHandle
    -_registry: SourceReaderRegistry
    +set_reply_to(handle)
  }

  class SubtreeWorkerActor {
    -_builder: AstBuilder
    -_reply_to: ActorHandle
    +set_reply_to(handle)
  }

  class ResultCollectorActor {
    +result: AstDocument
  }

  ParserRuntimeFactory --> ParserRuntime : создаёт
  ParserRuntimeFactory --> ParserCoordinatorActor : создаёт
  ParserRuntimeFactory --> DocumentReaderActor : создаёт
  ParserRuntimeFactory --> SubtreeWorkerActor : создаёт ×N
  ParserRuntimeFactory --> ResultCollectorActor : создаёт

  ParserRuntime *-- "1" ManualActorDriver
  ParserRuntime *-- "1" ParserCoordinatorActor
  ParserRuntime *-- "1" ResultCollectorActor

  ParserCoordinatorActor --> ActorHandle : reader, workers[], collector
  DocumentReaderActor --> ActorHandle : reply_to
  SubtreeWorkerActor --> ActorHandle : reply_to

  ParserCoordinatorActor --> ReadDocumentRequest
  ParserCoordinatorActor --> BuildSubtreeRequest
  DocumentReaderActor --> DocumentLoaded
  SubtreeWorkerActor --> SubtreeCompleted
  ParserCoordinatorActor --> ParseCompleted

  DocumentReaderActor --> ParserConfig
  DocumentReaderActor --> SourceReaderRegistry
  SubtreeWorkerActor --> AstBuilder
  ResultCollectorActor --> AstDocument

  DocumentLoaded --> SourceDocument
  BuildSubtreeRequest --> TextSegment
  SubtreeCompleted --> AstNode
  ParseCompleted --> AstDocument
}

Actor <|-- ParserCoordinatorActor
Actor <|-- DocumentReaderActor
Actor <|-- SubtreeWorkerActor
Actor <|-- ResultCollectorActor

ActorAstParser --> ConfigLoader
ActorAstParser --> ParserRuntimeFactory
ActorAstParser --> AstDocument : возвращает

note right of ActorAstParser
  Формат определяется по расширению файла,
  если format_name не передан явно.
end note

note bottom of ParserConfig
  Иерархия entities должна быть ацикличной.
  root_entity обязан ссылаться на существующую сущность.
end note

note bottom of ParserRuntimeFactory
  worker_count и driver_factory настраиваемы.
  По умолчанию: 4 worker'а, ManualActorDriver.
end note

@enduml
