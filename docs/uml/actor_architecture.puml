@startuml
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 35
skinparam ranksep 30
skinparam classAttributeIconSize 0
skinparam shadowing false
hide empty members

package "actor.output" {
  interface Output {
    +put(message)
  }
}

package "actor.handles" {
  class ActorHandle {
    -_output: Output
    +output: Output
    +put(message)
    +put(message)
  }

  ActorHandle ..|> Output
  ActorHandle --> "1" Output : делегирует отправку
}

package "actor.arch" {
  interface InboxLike {
    +get_nowait()
  }

  interface MailboxLike {
    +put(item)
    +__len__()
  }

  class Mailbox {
    -_items
    -_lock
    +put(item)
    +extend(items)
    +get_nowait()
    +empty()
    +__len__()
  }

  interface Drivable {
    +step(limit)
    +pending
  }

  abstract class Fsm {
    -_state_type
    -_inbox: InboxLike
    +state
    +state_type
    +states
    +inbox
    +step(limit)
    +extract_message(item)
    +handle(message)
    +on_unhandled_message(message)
    -_get_handler_name(state)
    -_iter_handler_names(state, message)
    -_validate_state(value)
  }

  abstract class Actor {
    -_mailbox: MailboxLike
    -_driver: ActorDriver
    +mailbox
    +driver
    +bind(driver)
    +put(item)
    +send(item)
    +extend(items)
    +pending
    +as_handle()
  }

  InboxLike <|-- MailboxLike
  InboxLike <|.. Mailbox
  MailboxLike <|.. Mailbox
  Drivable <|.. Actor
  Output <|.. Actor
  Fsm <|-- Actor
  Actor *-- "1" MailboxLike : владеет
  Actor ..> ActorHandle : создаёт
}

package "actor.scheduling" {
  abstract class ActorDriver {
    +bind(actor)
    +attach(actor)
    +schedule(actor)
    +is_idle()
    +queue_size()
    +close()
  }

  abstract class ProceedableActorDriver {
    +proceed(step_limit)
    +drain(step_limit)
  }

  abstract class BaseActorDriver {
    -_ready_actors: ReadyActors
    +attach(actor)
    +schedule(actor)
    +is_idle()
    +queue_size()
    #_pop_ready_actor()
    #_complete_actor(actor)
    #_schedule_actor(actor)
  }

  class ReadyActors {
    -_scheduled
    -_ready
    -_inflight
    +attach(actor)
    +schedule(actor)
    +pop()
    +complete(actor)
    +is_idle()
    +queue_size()
  }

  ActorDriver <|-- ProceedableActorDriver
  ActorDriver <|-- BaseActorDriver
  BaseActorDriver *-- "1" ReadyActors : владеет
}

Actor --> "0..1" ActorDriver : привязан к

Output -[hidden]right-> InboxLike
Mailbox -[hidden]right-> ActorDriver
Actor -[hidden]right-> ActorDriver

@enduml
